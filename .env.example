# =============================================================================
# N8N Self-Hosted — Environment Variables
# Run ./setup.sh to generate this automatically, or copy to .env and fill in.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=          # REQUIRED: strong password
POSTGRES_DB=n8n

# --- N8N Security ---
N8N_ENCRYPTION_KEY=         # REQUIRED: openssl rand -hex 32
N8N_JWT_SECRET=             # REQUIRED: openssl rand -hex 32

# --- N8N Host ---
N8N_HOST=localhost          # Your domain or IP address
N8N_PROTOCOL=https

# --- TLS ---
# For Let's Encrypt (requires domain):
#   ACME_EMAIL=you@example.com
#   TRAEFIK_RULE=Host(`n8n.example.com`)
#   Then run: setup.sh (generates docker-compose.override.yml with certresolver)
#
# For self-signed (IP or localhost):
#   ACME_EMAIL=
#   TRAEFIK_RULE=PathPrefix(`/`)
ACME_EMAIL=
TRAEFIK_RULE=PathPrefix(`/`)
