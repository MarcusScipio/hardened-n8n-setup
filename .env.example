# =============================================================================
# N8N Self-Hosted — Environment Variables
# Copy this file to .env and fill in real values
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=          # REQUIRED: strong password for postgres
POSTGRES_DB=n8n

# --- N8N Security ---
N8N_ENCRYPTION_KEY=         # REQUIRED: openssl rand -hex 32
N8N_JWT_SECRET=             # REQUIRED: openssl rand -hex 32

# --- N8N Host ---
N8N_HOST=n8n.example.com   # REQUIRED: your domain pointing to this server

# --- Let's Encrypt ---
ACME_EMAIL=you@example.com  # REQUIRED: email for TLS certificate notifications
