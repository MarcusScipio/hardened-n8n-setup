# =============================================================================
# Monitoring Stack — Environment Variables
# Copy this file to .env and fill in real values
# =============================================================================

# --- Must match values from the parent ../.env ---
POSTGRES_USER=n8n
POSTGRES_PASSWORD=          # Must match the n8n stack's POSTGRES_PASSWORD
POSTGRES_DB=n8n

# --- Grafana ---
GF_SECURITY_ADMIN_PASSWORD= # REQUIRED: strong password for Grafana admin
